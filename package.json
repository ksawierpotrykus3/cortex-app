{
  "name": "nexus-system",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "./out/main/index.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:bridge": "node \"%USERPROFILE%/Pictures/Screenshots/trae/server.mjs\"",
    "dev:full": "concurrently -k \"npm run dev:bridge\" \"npm run dev\"",
    "dev:renderer": "vite --port=3000 --host=0.0.0.0",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently -k \"npm run dev:renderer\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "electron-vite build && electron-builder",
    "clean": "rimraf dist out server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --headed"
  },
  "dependencies": {
    "@google/genai": "^2.7.0",
    "@tailwindcss/oxide": "^4.3.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^11.8.0",
    "electron-vite": "^2.3.0",
    "flatted": "^3.4.2",
    "idb-keyval": "^6.2.5",
    "lightningcss": "^1.32.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.40.0",
    "playwright": "^1.61.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-window": "^1.8.11",
    "vite": "^6.2.3",
    "zod": "^3.25.76",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.14.0",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.12",
    "jsdom": "^29.1.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.nexus.app",
    "productName": "Nexus System",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "dist/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
