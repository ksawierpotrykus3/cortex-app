{
  "name": "nexus-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "electron": "wait-on http://localhost:3000 && electron .",
    "electron:dev": "concurrently -k \"npm run dev\" \"npm run electron\"",
    "electron:build": "vite build && electron-builder",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google/genai": "^2.7.0",
    "@tailwindcss/oxide": "^4.3.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "chokidar": "^5.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "idb": "^8.0.3",
    "idb-keyval": "^6.2.5",
    "flatted": "^3.3.2",
    "lightningcss": "^1.32.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.40.0",
    "react-window": "^1.8.11",
    "zod": "^3.24.2",
    "onnxruntime-node": "^1.26.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react-window": "^1.8.8",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.nexus.app",
    "productName": "Nexus System",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
